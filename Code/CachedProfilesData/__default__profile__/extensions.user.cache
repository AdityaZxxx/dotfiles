4","publisherDisplayName":"Apility AS","targetPlatform":"undefined","updated":false,"isPreReleaseVersion":false,"hasPreReleaseVersion":false,"size":1040948},"isValid":true,"validations":[],"preRelease":false},{"type":1,"identifier":{"id":"entuent.fira-code-nerd-font","uuid":"e16a19b1-65f8-4260-9bef-0712f51ab3e2"},"manifest":{"name":"fira-code-nerd-font","displayName":"Fira Code Nerd Font / Icons","description":"Use Nerd Font icons and install Fira Code","publisher":"entuent","repository":"https://github.com/intellis-team/fira-code-nerd-icons","version":"0.0.3","icon":"./icon.jpg","engines":{"vscode":"^1.80.0"},"categories":["Themes"],"contributes":{"iconThemes":[{"id":"fira-code-material-minimal","label":"Fira Code Material Minimal Icons","path":"./fira-code-material-minimal.json"}]}},"location":{"$mid":1,"path":"/home/aditya/.vscode/extensions/entuent.fira-code-nerd-font-0.0.3","scheme":"file"},"isBuiltin":false,"targetPlatform":"undefined","publisherDisplayName":"Entuent","metadata":{"installedTimestamp":1737557318227,"pinned":false,"source":"gallery","id":"e16a19b1-65f8-4260-9bef-0712f51ab3e2","publisherId":"db68b045-55d1-4a23-8b05-b769013f24b9","publisherDisplayName":"Entuent","targetPlatform":"undefined","updated":false,"isPreReleaseVersion":false,"hasPreReleaseVersion":false,"size":1218214},"isValid":true,"validations":[],"preRelease":false},{"type":1,"identifier":{"id":"codeium.codeium","uuid":"acab4f40-b6db-42ec-bcd1-01802cbdd988"},"manifest":{"name":"codeium","displayName":"Codeium: AI Coding Autocomplete and Chat for Python, Javascript, Typescript, Java, Go, and more","description":"The modern coding superpower: free AI code acceleration plugin for your favorite languages. Type less. Code more. Ship faster.","version":"1.30.18","publisher":"Codeium","icon":"assets/icon.png","galleryBanner":{"color":"#191919","theme":"dark"},"engines":{"vscode":"^1.68.0"},"bugs":{"url":"https://discord.gg/3XFf78nAx5","email":"support@codeium.com"},"categories":["AI","Chat","Programming Languages","Machine Learning","Snippets","Education"],"keywords":["ai","autocomplete","intellicode","intellisense","code completion","chatgpt","bash","c","cpp","c++","css","go","golang","html","java","javascript","jupyter","kotlin","node","nodejs","php","python","react","ruby","rust","swift","typescript"],"activationEvents":["onStartupFinished"],"main":"./dist/extension.js","contributes":{"configuration":{"title":"Codeium","properties":{"codeium.enableConfig":{"type":"object","default":{"*":true},"description":"Enable / disable Codeium globally or for specific languages"},"codeium.detectProxy":{"type":"boolean","default":true,"description":"Enable automatic proxy detection."},"codeium.enableSearch":{"type":["boolean","string"],"default":"default","description":"Enable the Codeium Indexing Engine. This feature allows chat and autocomplete models to have full codebase awareness, significantly improving autocomplete and chat quality. It also allows natural language search of your codebase. \n\n When first enabled, Codeium will consume about 25% of CPU while it indexes the workspace. This should take < 10 minutes depending on your workspace size, once per workspace. CPU usage will return to normal automatically.","enum":[true,"default",false],"enumDescriptions":["On","Default (defer to Codeium's judgement)","Off"]},"codeium.searchMaxWorkspaceFileCount":{"type":"integer","default":5000,"description":"Conditional on indexing being enabled, Codeium will attempt to index workspaces that have up to this many files. This file count ignores .gitignore and binary files. Raising this limit from default may lead to performance issues. Values 0 or below will be treated as unlimited."},"codeium.indexingRetentionPeriod":{"type":"integer","default":30,"description":"Indexed files that have not been accessed within this retention period in days will be removed."},"codeium.snoozeTime":{"type":"integer","default":60,"description":"Snooze time in minutes. After this amount of time, Codeium autocomplete will resume globally."},"codeium.languageServerStartupTimeout":{"type":"integer","default":15,"description":"Time in seconds the language server will have to start before timeout."},"codeium.enableCommandSideHintEducation":{"type":"boolean","default":true,"description":"Show the Codeium Command shortcut upon selecting multiple lines of text"},"codeium.enableCodeLens":{"type":["boolean","string"],"default":true,"description":"AI-powered inline action buttons in your editor.","enum":[true,"hide_x",false],"enumDescriptions":["Always show","Always show, but hide the x","Never show"]},"codeium.useSecretStorage":{"type":"boolean","default":true,"description":"Prefer using VS Code secrets over local storage for credentials."},"codeium.aggressiveShutdown":{"type":"boolean","default":false,"description":"Use this setting if the language server process doesn't exit after VS Code closes."},"codeium.enableExplainProblem":{"type":"boolean","default":true,"description":"AI Powered `Codeium: Explain Problem` hover pop-up."},"codeium.enableInComments":{"type":"boolean","default":true,"description":"If true, Codeium will provide autocomplete suggestions in comments."},"codeium.indexStoragePath":{"type":"string","default":"","description":"Custom absolute path to store Codeium index data. Use in cases when the home directory is an NFS mount so the path is on local disk."},"codeium.disableSupercomplete":{"type":"boolean","default":false,"description":"Whether to disable Codeium Supercomplete (Beta)."},"codeium.disableTabJump":{"type":"boolean","default":false,"description":"Disable tab to jump functionality."}}},"viewsContainers":{"activitybar":[{"id":"codeium","title":"Codeium","icon":"assets/codeium.svg"}]},"views":{"codeium":[{"type":"webview","id":"codeium.chatPanelView","name":"Codeium","visibility":"visible"}]},"commands":[{"command":"codeium.provideAuthToken","title":"Codeium: Provide Authentication Token"},{"command":"codeium.showPreviousCompletion","title":"Codeium: Show Previous Completion"},{"command":"codeium.showNextCompletion","title":"Codeium: Show Next Completion"},{"command":"codeium.toggleAutocompleteForCurrentLanguage","title":"Codeium: Toggle Autocomplete for Current Language"},{"command":"codeium.toggleAutocompleteGlobally","title":"Codeium: Toggle Autocomplete Globally"},{"command":"codeium.toggleSupercomplete","title":"Codeium: Toggle Supercomplete"},{"command":"codeium.copyStatusToClipboard","title":"Codeium: Copy Status to Clipboard"},{"command":"codeium.openProfile","title":"Codeium: Open Profile","icon":"$(accounts-view-bar-icon)"},{"command":"codeium.popoutChat","title":"Codeium: Popout Chat","icon":"$(default-view-icon)"},{"command":"codeium.generateCommitMessage","title":"Codeium: Generate Commit Message (beta)","icon":"$(sparkle)"},{"command":"codeium.openChatView","title":"Codeium: Open Chat"},{"command":"codeium.openChatInPane","title":"Codeium: Open Chat in Editor","icon":"$(preferences-open-settings)"},{"command":"codeium.refactorCodeBlock","title":"Codeium: Refactor Selected Code Block"},{"command":"codeium.explainCodeBlock","title":"Codeium: Explain Selected Code Block"},{"command":"codeium.openUniversityView","title":"Codeium: Open University","when":"codeium.universityEnabled","icon":"$(extensions-info-message)"},{"command":"codeium.explainProblem","title":"Codeium: Explain Problem"},{"command":"codeium.openCodeiumCommand","title":"Codeium: Command ✨"},{"command":"codeium.pasteAndTranslate","title":"Codeium: Smart Paste 🧠"},{"command":"codeium.cancelCommandComment","title":"Cancel Command"},{"command":"codeium.submitCodeiumCommand","title":"Codeium: Submit ✨"},{"command":"codeium.openAutocompleteCommandPalette","title":"Codeium: Open Autocomplete Command Palette"},{"command":"codeium.snoozeAutocomplete","title":"Codeium: Snooze Autocomplete"},{"command":"codeium.cancelSnooze","title":"Codeium: Cancel Snooze"},{"command":"codeium.restartLanguageServer","title":"Codeium: Restart Language Server"},{"command":"codeium.testNetworkConnection","title":"Codeium: Test Network Connection"}],"menus":{"commandPalette":[{"command":"codeium.showPreviousCompletion","when":"inlineSuggestionVisible && !editorReadonly"},{"command":"codeium.showNextCompletion","when":"inlineSuggestionVisible && !editorReadonly"},{"command":"codeium.openCodeiumCommand","when":"codeium.commandEnabled"},{"command":"codeium.pasteAndTranslate","when":"codeium.commandEnabled && !(hasSpeechProvider && !editorReadonly && !speechToTextInProgress)"}],"editor/context":[{"command":"codeium.refactorCodeBlock","group":"CodeiumGroup@1","when":"editorTextFocus && editorHasSelection"},{"command":"codeium.explainCodeBlock","group":"CodeiumGroup@2","when":"editorTextFocus && editorHasSelection"}],"comments/commentThread/context":[{"command":"codeium.submitCodeiumCommand","group":"inline","when":"codeium.commandEnabled && commentController =~ /^codeium-command-comment-thread/"}],"comments/comment/context":[{"command":"codeium.cancelCommandComment","group":"inline@1","when":"codeium.commandEnabled && commentController =~ /^codeium-command-using-comment/"},{"command":"codeium.submitCodeiumCommand","group":"inline@0","when":"codeium.commandEnabled && commentController =~ /^codeium-command-using-comment/"}],"scm/title":[{"command":"codeium.generateCommitMessage","when":"scmProvider == git","group":"navigation"}]},"keybindings":[{"key":"alt+[","command":"codeium.showPreviousCompletion"},{"key":"alt+]","command":"codeium.showNextCompletion"},{"key":"alt+.","command":"codeium.showNextCortexStep"},{"key":"alt+,","command":"codeium.showPreviousCortexStep"},{"key":"ctrl+shift+a","mac":"shift+cmd+a","command":"codeium.openChatView","when":"isMac || isWindows"},{"key":"ctrl+alt+v","mac":"cmd+alt+v","command":"codeium.pasteAndTranslate"},{"key":"ctrl+alt+a","command":"codeium.openChatView","when":"isLinux"},{"command":"editor.action.inlineSuggest.trigger","key":"alt+\\","when":"editorTextFocus && !editorHasSelection && !inlineSuggestionsVisible"},{"command":"codeium.openCodeiumCommand","key":"ctrl+i","mac":"cmd+i","when":"editorTextFocus && !inlineSuggestionsVisible && codeium.commandEnabled"},{"command":"codeium.smartCopy","key":"ctrl+c","mac":"cmd+c","when":"editorTextFocus && codeium.enableSmartCopy"},{"command":"codeium.openCodeiumCommand","key":"ctrl+shift+i","mac":"cmd+shift+i","when":"editorTextFocus && !inlineSuggestionsVisible && codeium.commandEnabled"},{"command":"codeium.cancelCodeiumCommand","key":"alt+c","mac":"alt+c","when":"editorTextFocus && codeium.commandEnabled"},{"command":"codeium.diffActionAccept","key":"alt+a","mac":"alt+a","when":"editorTextFocus && !inlineSuggestionsVisible"},{"command":"codeium.diffActionFollowup","key":"alt+f","mac":"alt+f","when":"editorTextFocus && !inlineSuggestionsVisible"},{"command":"codeium.diffActionReject","key":"alt+r","mac":"alt+r","when":"editorTextFocus && !inlineSuggestionsVisible"},{"command":"editor.action.submitComment","key":"ctrl+shift+enter","mac":"cmd+shift+enter","when":"commentEditorFocused"},{"command":"codeium.supercompleteAccept","key":"tab","mac":"tab","when":"editorTextFocus && !inlineSuggestionsVisible && codeium.supercompleteShown && codeium.supercompleteOnTab"},{"command":"codeium.forceSupercomplete","key":"alt+.","mac":"alt+.","when":"editorTextFocus"},{"command":"codeium.supercompleteEscape","key":"escape","mac":"escape","when":"editorTextFocus && codeium.supercompleteShown"},{"command":"codeium.tabJumpAccept","key":"tab","mac":"tab","when":"editorTextFocus && !inlineSuggestionsVisible && codeium.tabJumpShown && codeium.tabJumpEnabled"},{"command":"codeium.chatAboutBlock","key":"alt+l","mac":"alt+l","when":"editorTextFocus && !inlineSuggestionsVisible"}]},"scripts":{"vscode:prepublish":"pnpm webpack-prod && pnpm lint","webpack":"pnpm protoc && webpack --mode development --progress","webpack-watch":"pnpm webpack --mode development --watch","webpack-prod":"pnpm webpack --mode production && pnp